# API Key
OPENAI_API_KEY=sk-...

# 自定义 API 服务商地址（用官方端点则留空）
# 示例: OpenAI 兼容接口 (Ollama / vLLM / 中转站等)
OPENAI_BASE_URL=

# 模型选择
ANSWER_MODEL=gpt-4o-mini
CRITIQUE_MODEL=gpt-4o

# 服务配置
HOST=127.0.0.1
PORT=8000
MAX_TOKENS=4096

# 安全配置
RATE_LIMIT_PER_HOUR=30
MAX_MESSAGE_LENGTH=2000
MAX_MESSAGES=50
# CORS 允许来源，生产环境应设为实际域名，如: https://your-domain.com
# 留空表示禁止所有跨域请求
CORS_ORIGINS=
# 是否允许运行时通过 API 修改配置（生产环境建议设为 false）
ALLOW_CONFIG_UPDATE=false
# 访问 API 所需的密钥，留空则不启用认证（生产环境强烈建议设置）
API_KEY=
# 受信的反向代理 IP（逗号分隔），只有来自这些 IP 的请求才会信任 X-Forwarded-For
TRUSTED_PROXIES=
